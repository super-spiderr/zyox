# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Zyox' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |sub_config|
        sub_config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        
        # Ensure HERMES_V1_ENABLED=1 is defined for all pods when Hermes V1 is enabled
        if ENV['RCT_HERMES_V1_ENABLED'] != '0'
          current_defs = sub_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
          if current_defs.nil?
            sub_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = ['$(inherited)', 'HERMES_V1_ENABLED=1']
          elsif current_defs.is_a?(Array)
            unless current_defs.include?('HERMES_V1_ENABLED=1')
              current_defs << 'HERMES_V1_ENABLED=1'
              sub_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = current_defs
            end
          elsif current_defs.is_a?(String)
            unless current_defs.include?('HERMES_V1_ENABLED=1')
              sub_config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = "#{current_defs} HERMES_V1_ENABLED=1"
            end
          end
        end
      end
    end
  end
end
